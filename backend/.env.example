# LLM backend: gemini (default) | groq | openrouter | ollama
LLM_PROVIDER=gemini
# Optional: cap completion tokens for all backends
# LLM_MAX_TOKENS=8000

# --- Gemini (when LLM_PROVIDER=gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_TIMEOUT=240

# --- Groq (when LLM_PROVIDER=groq) ---
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# --- OpenRouter (when LLM_PROVIDER=openrouter) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5
# Set to 1 if OpenRouter hangs (broken system HTTP_PROXY / corporate proxy)
OPENROUTER_IGNORE_SYSTEM_PROXY=
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_APP_TITLE=DevCareer

# --- Ollama (when LLM_PROVIDER=ollama) ---
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.1:latest
# OLLAMA_TIMEOUT=600
# OLLAMA_MAX_TOKENS=4096
# OLLAMA_API_KEY=ollama

GITHUB_TOKEN=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
REED_API_KEY=
